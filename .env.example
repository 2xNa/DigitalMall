# DigitalMall 环境变量配置
# 复制此文件为 .env 并填写你自己的密钥

# Django 密钥（生产环境请用强随机字符串）
# 生成方式: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# 调试模式（生产环境设为 False）
DJANGO_DEBUG=True

# 智谱 AI 聊天 API 配置（可选，不配置则使用关键词回复）
# 注册获取: https://open.bigmodel.cn/
CHATBOT_API_KEY=your_chatbot_api_key_here
CHATBOT_MODEL=glm-4-flash
